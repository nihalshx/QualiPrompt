# ──────────────────────────────────────────────
# Prompt Quality Tester — Environment Variables
# ──────────────────────────────────────────────
# Copy this file to .env and fill in your keys.

# Google Gemini API key (required)
# Obtain from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Hugging Face token (optional — only needed for dataset publishing)
# Obtain from: https://huggingface.co/settings/tokens
HF_TOKEN=your_huggingface_token_here

# Hugging Face repo name for dataset publishing (optional)
# Format: "your-username/your-dataset-name"
HF_DATASET_REPO=your-username/prompt-quality-dataset
